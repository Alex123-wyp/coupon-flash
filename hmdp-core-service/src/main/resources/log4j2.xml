<?xml version="1.0" encoding="UTF-8"?>
<!--
    status: controls Log4j2's own internal diagnostic output. It can be omitted, and when set to trace you will see detailed internal logs.
    monitorInterval: the number of seconds between configuration file checks so Log4j can detect changes and reload itself automatically.
-->
<!-- configuration>loggers>root -->
<!-- priority from high to low: OFF, FATAL, ERROR, WARN, INFO, DEBUG, TRACE, ALL -->
<Configuration status="WARN" monitorInterval="600">

    <Properties>
        <!-- configure the log output directory -->
        <Property name="LOG_HOME">.</Property>
        <Property name="PROJECT_NAME">core-service</Property>
        <Property name="ENV">local</Property>
        <Property name="FILE_NAME">log</Property>
        <Property name="PATTERN">[core-service] %d{yyyy-MM-dd HH:mm:ss} %5p %c{1}:%L - %m%n</Property>
        <Property name="ENCODING">UTF-8</Property>
        <Property name="CUSTOM_MESSAGE_KEY">org.yupeng</Property>
    </Properties>

    <Appenders>
        <!-- console output configuration -->
        <Console name="Console" target="SYSTEM_OUT">
            <!-- the console only outputs logs at or above the matched level; other logs are rejected -->
            <!--  <ThresholdFilter level="trace" onMatch="ACCEPT" onMismatch="DENY"/> -->
            <!-- log output pattern -->
            <PatternLayout pattern="${PATTERN}"/>
            <ThresholdFilter level="INFO"/>
        </Console>

        <!-- write to the log file -->
        <RollingFile name="RollingFile" fileName="${LOG_HOME}/logs/${PROJECT_NAME}/${FILE_NAME}.log"
                     filePattern="${LOG_HOME}/logs/${PROJECT_NAME}/$${date:yyyy-MM}/${FILE_NAME}-%d{yyyy-MM-dd}-%i.log.gz">
            <ThresholdFilter level="INFO"/>
            <PatternLayout charset="${ENCODING}" pattern="${PATTERN}"/>
            <Policies>
                <!-- interval: integer value that specifies the time between two rollover actions. The unit depends on the naming precision, for example yyyy-MM-dd-HH means hours and yyyy-MM-dd-HH-mm means minutes.
                    modulate: boolean value that indicates whether the rollover time should be aligned. When modulate=true, rollover is aligned against a midnight boundary. -->
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="100 MB"/>
            </Policies>
            <!-- maximum number of retained files -->
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>

        <!-- write error output to the log file -->
        <RollingFile name="RollingFileError" fileName="${LOG_HOME}/logs/${PROJECT_NAME}/${FILE_NAME}-error.log"
                     filePattern="${LOG_HOME}/logs/${PROJECT_NAME}/$${date:yyyy-MM}/${FILE_NAME}-error-%d{yyyy-MM-dd}-%i.log.gz">
            <ThresholdFilter level="ERROR"/>
            <PatternLayout charset="${ENCODING}" pattern="${PATTERN}"/>
            <Policies>
                <!-- interval: integer value that specifies the time between two rollover actions. The unit depends on the naming precision, for example yyyy-MM-dd-HH means hours and yyyy-MM-dd-HH-mm means minutes.
                    modulate: boolean value that indicates whether the rollover time should be aligned. When modulate=true, rollover is aligned against a midnight boundary. -->
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="100 MB"/>
            </Policies>
            <!-- maximum number of retained files -->
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- filter out unnecessary DEBUG logs from Spring and MyBatis -->
        <logger name="org.springframework" level="INFO" additivity="true"/>
        <logger name="org.mybatis" level="INFO" additivity="true"/>
        <logger name="org.springframework.jdbc.core" additivity="false" level="INFO" />
        <!-- configure the root logger -->
        <root level="INFO">
            <appender-ref ref="Console"/>
            <appender-ref ref="RollingFile"/>
            <appender-ref ref="RollingFileError"/>
        </root>
    </Loggers>
</Configuration>
